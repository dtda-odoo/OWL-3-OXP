<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoo_todo.TodoApp">
        <div class="o_todo_app">

            <div class="o_stats">

                <div class="o_stat_card">
                    <span class="o_stat_value">
                        <t t-out="this.store.totalTodos()"/>
                    </span>
                    <span class="o_stat_label">
                        Total
                    </span>
                </div>

                <div class="o_stat_card">
                    <span class="o_stat_value text-success">
                        <t t-out="this.store.completedTodos()"/>
                    </span>
                    <span class="o_stat_label">
                        Completed
                    </span>
                </div>

                <div class="o_stat_card">
                    <span class="o_stat_value text-warning">
                        <t t-out="this.store.pendingTodos()"/>
                    </span>
                    <span class="o_stat_label">
                        Pending
                    </span>
                </div>

            </div>

            <Card>

                <t t-set-slot="title">
                    <h3>Today's Tasks</h3>
                </t>

                <t t-set-slot="default">
                    <div class="o_todo_list">
                        <t t-foreach="this.store.todos()" t-as="todo" t-key="todo.id">
                            <TodoItem todo="todo"/>
                        </t>
                    </div>
                </t>

                <t t-set-slot="footer">
                    <button
                        class="btn btn-primary"
                        t-on-click="() => this.store.openCreate()"
                    >
                        Add Todo
                    </button>
                </t>

            </Card>
        </div>
        <TodoDialog
            t-if="this.store.dialog.isOpen"
        />
    </t>
</templates>
