<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="odoo_todo.TodoDialog">
        <div class="o_todo_dialog_backdrop">
            <div class="o_todo_dialog">

                <div class="o_dialog_header">
                    <h4>
                        <t t-if="this.store.dialog.mode === 'create'">
                            Create Todo
                        </t>
                        <t t-else="">
                            Edit Todo
                        </t>
                    </h4>
                </div>

                <div class="o_dialog_body">
                    <label class="form-label">
                        Title
                    </label>
                    <input
                        t-ref="this.inputRef"
                        class="form-control"
                        t-att-value="this.store.dialog.title"
                        t-on-input="this.onInput"
                    />
                </div>

                <div class="o_dialog_footer">
                    <button
                        class="btn btn-secondary"
                        t-on-click="this.onCancel"
                    >
                        Cancel
                    </button>
                    <button
                        class="btn btn-primary"
                        t-on-click="this.onSave"
                    >
                        Save
                    </button>
                </div>

            </div>
        </div>
    </t>

</templates>
