<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="odoo_todo.TodoItem">

    <div class="o_todo_item">

        <input
            type="checkbox" class="checkbox"
            t-att-checked="this.props.todo.completed"
            t-on-change="() => this.props.onToggle(this.props.todo)"
        />

        <h1
            t-att-class="{
                'text-decoration-line-through text-muted': this.props.todo.completed
            }"
        >
            <t t-out="this.props.todo.title"/>
        </h1>

        <div class="d-flex gap-2 ms-auto">
            <button
                class="btn btn-sm btn-outline-secondary"
                t-on-click="() => this.props.onEdit(this.props.todo)"
            >
                Edit
            </button>

            <button
                class="btn btn-sm btn-outline-danger"
                t-on-click="() => this.props.onDelete(this.props.todo)"
            >
                Delete
            </button>
        </div>

    </div>

</t>

</templates>
