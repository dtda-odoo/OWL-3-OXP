<t t-name="odoo_todo.TodoItem">

    <div class="o_todo_item">

        <input
            type="checkbox"
            class="form-check-input"
            t-att-checked="this.props.todo.completed"
            t-on-change="() => this.store.toggleTodo(this.props.todo)"
        />

        <h1
            t-att-class="{
                'text-decoration-line-through text-muted': this.props.todo.completed
            }"
        >
            <t t-out="this.props.todo.title"/>
        </h1>

        <div class="btn-group ms-auto">

            <button
                class="btn btn-outline-secondary btn-sm"
                t-on-click="() => this.store.openEdit(this.props.todo)"
            >
                Edit
            </button>

            <button
                class="btn btn-outline-danger btn-sm"
                t-on-click="() => this.store.deleteTodo(this.props.todo)"
            >
                Delete
            </button>

        </div>

    </div>

</t>
